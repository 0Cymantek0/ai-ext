# Copy one of the environment files to configure local runs.
# This file documents the available variables and their default values.

# When true, the Chrome extension loads dev-only instrumentation hooks.
# NEVER enable this flag in production builds.
VITE_DEBUG_RECORDER=false

# Gemini API Key for cloud-based AI features (report generation, etc.)
# Get your API key from: https://aistudio.google.com/app/apikey
# Optional: If not set, cloud features will show appropriate error messages
VITE_GEMINI_API_KEY=
