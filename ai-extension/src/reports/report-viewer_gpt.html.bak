<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pocket Report</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-gradient: radial-gradient(circle at 20% 20%, rgba(56, 189, 248, 0.12), transparent 45%), radial-gradient(circle at 80% 0%, rgba(244, 114, 182, 0.1), transparent 40%), linear-gradient(160deg, #0b1022 0%, #111d3b 50%, #090b18 100%);
      --card-bg: rgba(15, 23, 42, 0.72);
      --card-border: rgba(148, 163, 184, 0.14);
      --card-shadow: 0 24px 60px -35px rgba(15, 23, 42, 0.9);
      --text-primary: #f8fafc;
      --text-secondary: #94a3b8;
      --text-muted: #cbd5f5;
      --accent: #38bdf8;
      --accent-strong: #f472b6;
      --accent-soft: rgba(56, 189, 248, 0.18);
      --badge-bg: linear-gradient(135deg, rgba(56, 189, 248, 0.18), rgba(59, 130, 246, 0.18));
      --tag-bg: rgba(148, 163, 184, 0.16);
      --radius-lg: 24px;
      --radius-md: 18px;
      --radius-sm: 12px;
      --radius-pill: 999px;
      --transition: 260ms cubic-bezier(0.34, 1.1, 0.64, 1);
      color-scheme: dark;
    }

    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      background: var(--bg-gradient);
      color: var(--text-primary);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      padding: 48px 20px 64px;
      line-height: 1.6;
      position: relative;
      overflow-x: hidden;
    }

    body::after {
      content: "";
      position: fixed;
      inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='240' height='240' viewBox='0 0 240 240' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cg opacity='0.12'%3E%3Cpath d='M0 120H240' stroke='%2394a3b8' stroke-width='0.5'/%3E%3Cpath d='M120 0V240' stroke='%2394a3b8' stroke-width='0.5'/%3E%3C/g%3E%3C/svg%3E") center/240px repeat;
      pointer-events: none;
      mix-blend-mode: screen;
      opacity: 0.4;
    }

    .container {
      max-width: 1080px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
      display: grid;
      gap: 32px;
    }

    .header {
      position: relative;
      background: linear-gradient(125deg, rgba(30, 64, 175, 0.85), rgba(79, 70, 229, 0.7));
      border-radius: var(--radius-lg);
      padding: 48px 48px 44px;
      overflow: hidden;
      box-shadow: 0 30px 80px -40px rgba(59, 130, 246, 0.6);
      isolation: isolate;
    }

    .header::before,
    .header::after {
      content: "";
      position: absolute;
      inset: -40% -20%;
      background: radial-gradient(circle at top right, rgba(244, 114, 182, 0.55), transparent 55%);
      opacity: 0.7;
      filter: blur(20px);
      transform: rotate(8deg);
    }

    .header::after {
      inset: auto -40px 0 40%;
      background: radial-gradient(circle at bottom left, rgba(56, 189, 248, 0.55), transparent 60%);
      transform: rotate(-4deg);
    }

    .header h1 {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: clamp(32px, 4vw, 44px);
      letter-spacing: -0.02em;
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }

    .header h1 span {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.18);
      backdrop-filter: blur(8px);
      font-size: 24px;
    }

    .header p {
      font-size: 18px;
      color: rgba(248, 250, 252, 0.78);
      max-width: 520px;
    }

    .btn {
      margin-top: 28px;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.22));
      color: #0f172a;
      border: none;
      padding: 14px 24px;
      border-radius: var(--radius-pill);
      font-weight: 600;
      font-size: 16px;
      cursor: pointer;
      letter-spacing: 0.01em;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      transition: var(--transition);
      position: relative;
      overflow: hidden;
      backdrop-filter: blur(6px);
    }

    .btn::before {
      content: "";
      position: absolute;
      inset: -20%;
      background: conic-gradient(from 120deg, rgba(56, 189, 248, 0.55), rgba(244, 114, 182, 0.55), rgba(56, 189, 248, 0.55));
      opacity: 0;
      transition: opacity var(--transition);
      z-index: -1;
    }

    .btn:hover {
      transform: translateY(-2px) scale(1.01);
      color: var(--text-primary);
      box-shadow: 0 20px 40px -25px rgba(56, 189, 248, 0.7);
    }

    .btn:hover::before {
      opacity: 1;
    }

    .btn:active {
      transform: translateY(0);
      box-shadow: none;
    }

    .card {
      background: var(--card-bg);
      border-radius: var(--radius-lg);
      padding: 36px 40px;
      border: 1px solid var(--card-border);
      box-shadow: var(--card-shadow);
      backdrop-filter: blur(18px);
    }

    .card h2 {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(24px, 2.8vw, 28px);
      font-weight: 600;
      letter-spacing: -0.015em;
      display: flex;
      align-items: center;
      gap: 10px;
      color: var(--text-primary);
      margin-bottom: 28px;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 32px;
    }

    .stat-card {
      border-radius: var(--radius-md);
      padding: 24px 22px;
      backdrop-filter: blur(12px);
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(148, 163, 184, 0.18);
      display: grid;
      gap: 8px;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }

    .stat-card::before {
      content: "";
      position: absolute;
      inset: -40% -20%;
      opacity: 0.85;
      z-index: -1;
      transition: opacity var(--transition);
    }

    .stat-card:nth-child(1)::before {
      background: linear-gradient(135deg, rgba(59, 130, 246, 0.45), rgba(37, 99, 235, 0.35));
    }

    .stat-card:nth-child(2)::before {
      background: linear-gradient(135deg, rgba(236, 72, 153, 0.45), rgba(244, 114, 182, 0.32));
    }

    .stat-card:nth-child(3)::before {
      background: linear-gradient(135deg, rgba(16, 185, 129, 0.45), rgba(45, 212, 191, 0.32));
    }

    .stat-card:nth-child(4)::before {
      background: linear-gradient(135deg, rgba(248, 113, 113, 0.45), rgba(251, 191, 36, 0.32));
    }

    .stat-card:hover::before {
      opacity: 1;
    }

    .stat-value {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(28px, 3.5vw, 36px);
      font-weight: 600;
      color: var(--text-primary);
    }

    .stat-label {
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: rgba(248, 250, 252, 0.66);
    }

    .card p,
    .insight-section p {
      color: var(--text-secondary);
      font-size: 15px;
    }

    #generatedDate {
      color: var(--text-muted);
      font-weight: 500;
    }

    .insight-section {
      background: rgba(8, 47, 73, 0.18);
      border-radius: var(--radius-md);
      padding: 24px;
      border: 1px solid rgba(59, 130, 246, 0.12);
      margin-bottom: 22px;
      transition: transform var(--transition), box-shadow var(--transition);
    }

    .insight-section:last-of-type {
      margin-bottom: 0;
    }

    .insight-section:hover {
      transform: translateY(-2px);
      box-shadow: 0 20px 40px -35px rgba(56, 189, 248, 0.6);
    }

    .insight-section h3 {
      font-family: 'Outfit', sans-serif;
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 12px;
      color: var(--text-primary);
    }

    .insight-section ul {
      list-style: none;
      display: grid;
      gap: 12px;
      color: var(--text-secondary);
    }

    .insight-section li {
      position: relative;
      padding-left: 24px;
    }

    .insight-section li::before {
      content: "";
      position: absolute;
      left: 6px;
      top: 9px;
      width: 8px;
      height: 8px;
      border-radius: 2px;
      background: linear-gradient(135deg, rgba(56, 189, 248, 0.8), rgba(59, 130, 246, 0.8));
      box-shadow: 0 0 12px rgba(56, 189, 248, 0.7);
    }

    #aiThemes {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .theme-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--badge-bg);
      color: rgba(244, 244, 255, 0.9);
      padding: 8px 16px;
      border-radius: var(--radius-pill);
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.02em;
      border: 1px solid rgba(59, 130, 246, 0.25);
      text-transform: uppercase;
    }

    .content-item {
      background: rgba(15, 23, 42, 0.55);
      border-radius: var(--radius-md);
      padding: 26px 26px 22px;
      border: 1px solid rgba(148, 163, 184, 0.14);
      margin-bottom: 18px;
      transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
      position: relative;
    }

    .content-item:last-child {
      margin-bottom: 0;
    }

    .content-item:hover {
      transform: translateY(-4px);
      border-color: rgba(56, 189, 248, 0.45);
      box-shadow: 0 32px 60px -40px rgba(56, 189, 248, 0.75);
    }

    .content-title {
      font-size: 18px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 8px;
      letter-spacing: -0.01em;
    }

    .content-preview {
      font-size: 15px;
      color: var(--text-secondary);
      margin-bottom: 14px;
    }

    .tag {
      display: inline-flex;
      align-items: center;
      padding: 6px 14px;
      border-radius: var(--radius-pill);
      font-size: 12px;
      font-weight: 500;
      color: rgba(226, 232, 240, 0.92);
      background: var(--tag-bg);
      margin: 4px 6px 6px 0;
      border: 1px solid rgba(148, 163, 184, 0.22);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .content-meta {
      margin-top: 18px;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      font-size: 13px;
      color: rgba(226, 232, 240, 0.7);
    }

    .content-meta span {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: var(--radius-pill);
      background: rgba(30, 64, 175, 0.25);
      border: 1px solid rgba(37, 99, 235, 0.25);
    }

    .content-meta span.type {
      background: rgba(16, 185, 129, 0.22);
      border: 1px solid rgba(52, 211, 153, 0.22);
      color: rgba(16, 185, 129, 0.88);
    }

    .content-meta a {
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: var(--radius-pill);
      border: 1px solid rgba(56, 189, 248, 0.32);
      background: rgba(8, 47, 73, 0.4);
      transition: var(--transition);
    }

    .content-meta a:hover {
      color: var(--text-primary);
      border-color: rgba(56, 189, 248, 0.6);
      transform: translateX(2px);
    }

    .loading {
      text-align: center;
      padding: 80px 20px;
      border-radius: var(--radius-lg);
      background: rgba(15, 23, 42, 0.6);
      border: 1px dashed rgba(148, 163, 184, 0.22);
      backdrop-filter: blur(12px);
      color: var(--text-secondary);
    }

    .spinner {
      width: 64px;
      height: 64px;
      margin: 0 auto 20px;
      border-radius: 50%;
      background:
        radial-gradient(circle at center, #0f172a 45%, transparent 52%),
        conic-gradient(from 0deg, rgba(56, 189, 248, 0.85), rgba(99, 102, 241, 0.85), rgba(244, 114, 182, 0.85), rgba(56, 189, 248, 0.85));
      animation: spin 1.4s linear infinite;
      box-shadow: 0 20px 50px -26px rgba(56, 189, 248, 0.8);
    }

    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }

    .error {
      background: rgba(248, 113, 113, 0.14);
      color: #fee2e2;
      padding: 22px;
      border-radius: var(--radius-md);
      border: 1px solid rgba(248, 113, 113, 0.32);
      margin: 28px 0;
      backdrop-filter: blur(10px);
    }

    .hidden {
      display: none !important;
    }

    .footer {
      text-align: center;
      color: rgba(148, 163, 184, 0.66);
      font-size: 14px;
      letter-spacing: 0.04em;
      padding: 24px 0 12px;
    }

    .footer::before {
      content: "";
      display: block;
      width: 120px;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(148, 163, 184, 0.3), transparent);
      margin: 0 auto 18px;
    }

    @media (max-width: 768px) {
      body {
        padding: 32px 16px 48px;
      }

      .header {
        padding: 36px 28px 32px;
      }

      .header h1 {
        flex-direction: column;
        align-items: flex-start;
      }

      .header h1 span {
        margin-bottom: 10px;
      }

      .btn {
        width: 100%;
        justify-content: center;
      }

      .card {
        padding: 28px 24px;
      }

      .content-meta {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    @media print {
      body {
        background: #fff;
        color: #0f172a;
        padding: 20px;
      }

      body::after {
        display: none;
      }

      .header,
      .card,
      .loading {
        background: #fff !important;
        color: #0f172a;
        box-shadow: none;
        border: 1px solid #e2e8f0;
      }

      .header::before,
      .header::after {
        display: none;
      }

      .btn {
        display: none;
      }

      .stat-card,
      .insight-section,
      .content-item {
        background: #fff !important;
        border: 1px solid #e2e8f0;
        box-shadow: none;
      }

      .theme-badge,
      .tag,
      .content-meta span,
      .content-meta a {
        background: #f1f5f9 !important;
        color: #0f172a !important;
        border-color: #e2e8f0;
      }

      .spinner {
        display: none;
      }

      a {
        color: #1d4ed8 !important;
      }
    }
  </style>
</head>

<body>
  <div class="container">
    <!-- Header -->
    <div class="header">
      <h1><span>📊</span>Pocket Report</h1>
      <p>AI-powered intelligence for your saved content—summarized, themed, and ready for decision-making.</p>
      <button class="btn" onclick="window.print()">📄 Export / Print Report</button>
    </div>

    <!-- Loading State -->
    <div id="loading" class="loading">
      <div class="spinner"></div>
      <p>Crunching collections, distilling insights… almost there!</p>
    </div>

    <!-- Report Content -->
    <div id="reportContent" class="hidden">
      <!-- Overview -->
      <div class="card">
        <h2>📈 Report Overview</h2>
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-value" id="totalItems">0</div>
            <div class="stat-label">Total Items</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="pocketName">-</div>
            <div class="stat-label">Pocket</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="contentTypes">0</div>
            <div class="stat-label">Content Types</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="totalTags">0</div>
            <div class="stat-label">Unique Tags</div>
          </div>
        </div>
        <p>Generated on <span id="generatedDate"></span></p>
      </div>

      <!-- AI Insights -->
      <div class="card">
        <h2>🤖 AI Insights</h2>

        <div class="insight-section">
          <h3>Executive Summary</h3>
          <p id="aiSummary">Loading insights...</p>
        </div>

        <div class="insight-section">
          <h3>Main Themes</h3>
          <div id="aiThemes"></div>
        </div>

        <div class="insight-section">
          <h3>Key Findings</h3>
          <ul id="aiFindings" style="padding-left: 0;"></ul>
        </div>

        <div class="insight-section">
          <h3>Recommendations</h3>
          <ul id="aiRecommendations" style="padding-left: 0;"></ul>
        </div>
      </div>

      <!-- Content List -->
      <div class="card">
        <h2>📚 Content Items</h2>
        <div id="contentList"></div>
      </div>

      <!-- Footer -->
      <div class="footer">
        <p>Powered by AI Pocket Extension with Gemini Flash</p>
      </div>
    </div>
  </div>

  <script src="./report-viewer.js"></script>
</body>

</html>