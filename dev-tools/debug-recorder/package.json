{
  "name": "@ai-pocket/debug-recorder",
  "version": "0.1.0",
  "description": "CLI tool for capturing runtime state and generating diagnostic reports for AI Pocket extension",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "debug-recorder": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "keywords": [
    "debug",
    "diagnostics",
    "chrome-extension",
    "ai-pocket"
  ],
  "author": "AI Pocket Team",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  }
}
